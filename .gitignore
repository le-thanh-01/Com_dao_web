# 1. Bỏ qua thư viện khổng lồ (QUAN TRỌNG NHẤT)
node_modules/

# 2. Bỏ qua các file cấu hình môi trường chứa API Key, Mật khẩu
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Bỏ qua thư mục code đã được build ra để chạy thực tế
dist/
build/

# 4. Bỏ qua các file log lỗi của NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. Bỏ qua các file rác của hệ điều hành (Đặc biệt trên máy Mac)
.DS_Store